# Production Environment Configuration
# DO NOT commit actual secrets to version control
# Use AWS Secrets Manager or equivalent in production

# === Database ===
DATABASE_URL=postgresql://assessos:PASSWORD@assessos-db.us-east-1.rds.amazonaws.com:5432/assessos

# === Redis ===
REDIS_URL=redis://:AUTH_TOKEN@assessos-redis.us-east-1.cache.amazonaws.com:6379

# === Firebase ===
FIREBASE_PROJECT_ID=assessos-prod
FIREBASE_API_KEY=AIzaSyD...
FIREBASE_AUTH_DOMAIN=assessos-prod.firebaseapp.com
FIREBASE_DATABASE_URL=https://assessos-prod.firebaseio.com
FIREBASE_STORAGE_BUCKET=assessos-prod.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef123456

# === JWT ===
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# === Stripe ===
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_FREE=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# === Azure OpenAI ===
OPENAI_API_KEY=your-azure-openai-api-key
OPENAI_API_ENDPOINT=https://your-resource.openai.azure.com/
OPENAI_API_VERSION=2024-02-15-preview
OPENAI_MODEL=gpt-4o
OPENAI_DEPLOYMENT_NAME=gpt-4o

# === AWS ===
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/assessos-reports
S3_BUCKET=assessos-reports-prod

# === Application ===
NODE_ENV=production
LOG_LEVEL=info
DEBUG=false

# === Frontend ===
NEXT_PUBLIC_FIREBASE_PROJECT_ID=assessos-prod
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyD...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=assessos-prod.firebaseapp.com
NEXT_PUBLIC_API_URL=https://api.assessos.app

# === AI Sidecar ===
AI_SIDECAR_URL=http://assessos-ai-sidecar:8000

# === Observability ===
XRAY_SDK_ENABLED=true
CLOUDWATCH_ENABLED=true

# === Security ===
CORS_ORIGIN=https://assessos.app,https://www.assessos.app
SESSION_SECRET=your-session-secret-min-32-chars
ENCRYPTION_KEY=your-encryption-key-min-32-chars
