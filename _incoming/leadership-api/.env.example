# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_VERSION=v1

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Local:  postgresql://USER:PASS@localhost:5432/leaderassess
# Render: DATABASE_URL is injected automatically via render.yaml
DATABASE_URL=postgresql://postgres:password@localhost:5432/leaderassess

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# MongoDB Atlas: mongodb+srv://USER:PASS@cluster.mongodb.net/leaderassess
MONGODB_URI=mongodb://localhost:27017/leaderassess

# ─── Redis ────────────────────────────────────────────────────────────────────
# Render managed Redis provides REDIS_URL automatically.
# For local dev use REDIS_HOST/PORT instead.
# REDIS_URL=rediss://default:password@host:6380    ← Render/TLS
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_DB=0

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-at-least-32-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# ─── Email ────────────────────────────────────────────────────────────────────
# Production — Resend (https://resend.com, free tier: 3,000 emails/month)
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Development SMTP fallback (e.g. Mailhog localhost:1025)
SMTP_HOST=localhost
SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=
EMAIL_FROM=noreply@leaderassess.com

# ─── Code Execution (Judge0) ──────────────────────────────────────────────────
# Self-hosted: JUDGE0_API_URL=http://localhost:2358
# RapidAPI CE:
# JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
# JUDGE0_API_KEY=your-rapidapi-key

# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
