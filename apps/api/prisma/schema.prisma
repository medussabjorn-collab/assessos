datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id                String    @id @default(cuid())
  slug              String    @unique
  name              String
  plan              Plan      @default(free)
  whiteLabel        Json?
  ssoConfig         Json?
  settings          Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  users             User[]
  assessmentSessions AssessmentSession[]
  assessmentConfigs AssessmentConfig[]
  aiReports         AiReport[]
  subscriptions     Subscription[]
  candidates        Candidate[]
  psychometricResults PsychometricResult[]
  raterFeedback     RaterFeedback[]

  @@map("tenants")
}

enum Plan {
  free
  pro
  enterprise
}

model User {
  id                String    @id @default(cuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  firebaseUid       String    @unique
  email             String
  name              String
  role              Role      @default(employee)
  department        String?
  metadata          Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  assessmentSessions AssessmentSession[]
  aiReports         AiReport[]
  psychometricResults PsychometricResult[]
  raterFeedbackGiven    RaterFeedback[] @relation("RaterFeedbackRater")
  raterFeedbackReceived RaterFeedback[] @relation("RaterFeedbackSubject")

  @@index([tenantId])
  @@index([role])
  @@map("users")
}

enum Role {
  super_admin
  org_admin
  manager
  employee
}

model AssessmentSession {
  id                String    @id @default(cuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  configId          String
  config            AssessmentConfig @relation(fields: [configId], references: [id])
  pillar            String    @default("leadership")
  status            SessionStatus @default(pending)
  // [{ questionId, selectedOptionId, timeTakenSec }] captured at submission
  answers           Json?
  // { totalTimeTakenSec, answeredCount, skippedCount }
  answersMetadata   Json?
  startedAt         DateTime?
  submittedAt       DateTime?
  createdAt         DateTime  @default(now())

  aiReport          AiReport?
  raterFeedback     RaterFeedback[]

  @@index([tenantId])
  @@index([userId])
  @@map("assessment_sessions")
}

enum SessionStatus {
  pending
  active
  done
}

model AssessmentConfig {
  id                String    @id @default(cuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pillar            String    @default("leadership")
  dimensions        Json[]
  timeLimitMin      Int
  passMark          Int
  aiProctoring      Boolean   @default(true)
  benchmarkGroup    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sessions          AssessmentSession[]

  @@index([tenantId])
  @@map("assessment_configs")
}

model AiReport {
  id                String    @id @default(cuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessionId         String    @unique
  session           AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dimensionScores   Json
  narrative         String?
  benchmarkPercentile Int?
  recommendation    String?
  coachingPlan      Json?
  status            ReportStatus @default(pending)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([tenantId])
  @@index([sessionId])
  @@map("ai_reports")
}

enum ReportStatus {
  pending
  ready
  failed
  archived
}

model Subscription {
  id                String    @id @default(cuid())
  tenantId          String    @unique
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stripeCustomerId  String?
  stripeSubId       String?
  plan              Plan      @default(free)
  seats             Int       @default(5)
  assessmentCredits Int       @default(100)
  renewsAt          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("subscriptions")
}

enum PipelineStage {
  screening
  technical
  culture_fit
  offer
  hired
  rejected
}

model Candidate {
  id                String    @id @default(cuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // JobRole lives in the in-memory JobRoleService — plain string id + denormalized
  // title until roles are persisted.
  jobRoleId         String
  roleTitle         String
  firstName         String
  lastName          String
  email             String
  phone             String?
  linkedinUrl       String?
  resumeUrl         String?
  stage             PipelineStage @default(screening)
  technicalScore    Float?
  cultureFitScore   Float?
  assessmentSessionId String?
  notes             String?
  rejectionReason   String?
  createdBy         String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, jobRoleId])
  @@index([tenantId, stage])
  @@map("candidates")
}

// One row per psychometric model submission (DISC, Big Five, MBTI, ...).
// modelKey selects which PsychometricModel implementation produced this —
// scores/interpretation shapes are model-specific, validated by that
// model's own code, not by the schema. See modules/psychometric/.
model PsychometricResult {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  modelKey       String
  // Normalized per-dimension scores, e.g. DISC: { "D": 80, "I": 40, "S": 20, "C": 60 }
  scores         Json
  // Model-specific labels, e.g. DISC: { primaryType, secondaryType, profileLabel }
  interpretation Json
  // Audit trail of what was actually submitted, for re-scoring / disputes.
  rawAnswers     Json?
  createdAt      DateTime @default(now())

  @@index([tenantId])
  @@index([userId, modelKey])
  @@map("psychometric_results")
}

enum RaterRelationship {
  self
  manager
  peer
  direct_report
  other
}

// 360-feedback: one row per rater's submission about one subject, scoped to
// the subject's assessment session. A rater may only submit once per session
// (@@unique) — resubmission is an update, not a new row.
model RaterFeedback {
  id                String    @id @default(cuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessionId         String
  session           AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  subjectId         String
  subject           User      @relation("RaterFeedbackSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  raterId           String
  rater             User      @relation("RaterFeedbackRater", fields: [raterId], references: [id], onDelete: Cascade)
  relationship      RaterRelationship
  // Per-competency ratings, e.g. { "vision": 4, "execution": 3, ... }
  ratings           Json
  comments          String?
  // When true, the subject's own view of this feedback must omit raterId/rater
  // identity — enforced at the service layer, not just hidden client-side.
  isAnonymous       Boolean   @default(true)
  submittedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([sessionId, raterId])
  @@index([tenantId])
  @@index([sessionId])
  @@index([subjectId])
  @@map("rater_feedback")
}
