# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/assessos_dev

# Firebase
FIREBASE_PROJECT_ID=your-project
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----...
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@...
# Set to point the Admin SDK at a local Firebase Auth Emulator (firebase.json)
# instead of real Google Cloud credentials. When set, FIREBASE_PRIVATE_KEY only
# needs to be structurally valid PEM — its contents aren't checked.
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# DEV ONLY — bypass Firebase auth entirely, inject a fixed/header-overridable
# identity (see FirebaseAuthGuard). Never set true in a real deployment.
AUTH_DISABLED=false

# JWT
JWT_SECRET=your-secret-key-change-in-prod

# Redis
REDIS_URL=redis://localhost:6379

# Stripe
STRIPE_SECRET_KEY=sk_test_...

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SQS_QUEUE_URL=

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
