# Build stage
FROM node:20-alpine AS builder
WORKDIR /app
RUN npm install -g pnpm@9

# NEXT_PUBLIC_* vars must be present at BUILD time — Next.js statically
# inlines them into the client bundle during `next build`. Railway only
# injects dashboard-set Variables as container runtime env by default;
# ARG here opts these specific ones into Railway's build-arg passthrough
# (Railway auto-forwards any service Variable whose name matches a
# declared ARG). Without this, setting NEXT_PUBLIC_API_URL etc. in the
# dashboard silently has no effect on the deployed bundle — confirmed:
# it was set and redeployed with zero change to the built JS.
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_FIREBASE_API_KEY
ARG NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN
ARG NEXT_PUBLIC_FIREBASE_PROJECT_ID
ARG NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET
ARG NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID
ARG NEXT_PUBLIC_FIREBASE_APP_ID
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_FIREBASE_API_KEY=$NEXT_PUBLIC_FIREBASE_API_KEY
ENV NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=$NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN
ENV NEXT_PUBLIC_FIREBASE_PROJECT_ID=$NEXT_PUBLIC_FIREBASE_PROJECT_ID
ENV NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=$NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET
ENV NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=$NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID
ENV NEXT_PUBLIC_FIREBASE_APP_ID=$NEXT_PUBLIC_FIREBASE_APP_ID

# Copy the whole monorepo (node_modules excluded via .dockerignore) so the
# pnpm workspace resolves and Next's standalone output is produced.
COPY . .
RUN pnpm install
RUN pnpm --filter @assessos/web build

# Runtime stage
FROM node:20-alpine
WORKDIR /app
# pnpm in runtime: Railway sometimes carries a "pnpm start" start-command
# override from an earlier Nixpacks build; with pnpm present + the start
# script injected below, that override works instead of crash-looping.
RUN apk add --no-cache dumb-init && npm install -g pnpm@9
ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3001

# Standalone output in a pnpm monorepo nests the server under apps/web/.
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static

# Shell-level `PORT=3001 node server.js` was NOT enough — Railway's platform
# still delivered PORT=8080 to the running process regardless (confirmed via
# Railway's own diagnostics: "your Next.js app is listening on port 8080").
# Force it at the JS runtime level instead: this wrapper overwrites
# process.env before requiring the real server, which wins no matter what
# the process's inherited/platform environment contains.
# start.js is committed to apps/web/ and copied here so the file is always
# present — no fragile inline shell escaping required.
COPY --from=builder /app/apps/web/start.js ./start.js

# Inject a start script so `pnpm start` / `npm start` resolve to the same
# wrapper — a dashboard Custom Start Command of "pnpm start" must not be
# able to bypass the PORT/HOSTNAME override (this happened once already).
RUN node -e "const fs=require('fs');const p=JSON.parse(fs.readFileSync('package.json','utf8'));p.scripts=Object.assign({},p.scripts,{start:'node start.js'});fs.writeFileSync('package.json',JSON.stringify(p,null,2))"

RUN addgroup -g 1001 -S nodejs && adduser -S nodejs -u 1001
USER nodejs

EXPOSE 3001

HEALTHCHECK --interval=30s --timeout=3s --start-period=15s --retries=3 \
  CMD wget --quiet --tries=1 --spider http://localhost:3001/ || exit 1

ENTRYPOINT ["dumb-init", "--"]
CMD ["node", "start.js"]
