# Build stage
FROM node:20-alpine AS builder
WORKDIR /app
RUN npm install -g pnpm@9

# Copy the whole monorepo (node_modules excluded via .dockerignore) so the
# pnpm workspace resolves and Next's standalone output is produced.
COPY . .
RUN pnpm install
RUN pnpm --filter @assessos/web build

# Runtime stage
FROM node:20-alpine
WORKDIR /app
# pnpm in runtime: Railway sometimes carries a "pnpm start" start-command
# override from an earlier Nixpacks build; with pnpm present + the start
# script injected below, that override works instead of crash-looping.
RUN apk add --no-cache dumb-init && npm install -g pnpm@9
ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3001

# Standalone output in a pnpm monorepo nests the server under apps/web/.
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static

# Inject a start script so `pnpm start` / `npm start` resolve to the
# standalone server, same as the Dockerfile CMD.
RUN node -e "const fs=require('fs');const p=fs.existsSync('package.json')?JSON.parse(fs.readFileSync('package.json','utf8')):{};p.scripts=Object.assign({},p.scripts,{start:'node apps/web/server.js'});fs.writeFileSync('package.json',JSON.stringify(p,null,2))"

RUN addgroup -g 1001 -S nodejs && adduser -S nodejs -u 1001
USER nodejs

EXPOSE 3001

HEALTHCHECK --interval=30s --timeout=3s --start-period=15s --retries=3 \
  CMD wget --quiet --tries=1 --spider http://localhost:3001/ || exit 1

ENTRYPOINT ["dumb-init", "--"]
# HOSTNAME/PORT forced inline: the hosting platform may inject its own
# HOSTNAME env var (container id, used for internal DNS) which silently
# overrides our ENV HOSTNAME=0.0.0.0 above — Next's standalone server then
# tries to bind to that value and crashes before ever listening. Setting it
# on the exec line itself wins over any inherited/platform env for this
# specific process.
CMD ["sh", "-c", "HOSTNAME=0.0.0.0 PORT=${PORT:-3001} node apps/web/server.js"]
